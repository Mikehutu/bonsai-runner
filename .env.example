# 🪢 Bonsai 27B Runner Environment Configuration (.env.example)
# Copy this file to .env to override default parameters:
#   cp .env.example .env

# Server binding & port
PORT=8080
HOST=0.0.0.0

# GPU Offloading (set NGL=0 for pure CPU mode, NGL=99 for full GPU offload)
NGL=99

# Concurrent slots / parallel sessions (default: 4 auto for server, set NP=1 for single-user low memory)
NP=4

# Active context window length per slot (default: 4096, up to 262144)
CTX_SIZE=4096

# Host RAM reserved for prompt caching in MB (set CACHE_RAM=0 for laptops/12GB GPUs)
CACHE_RAM=8192

# Sampling parameters
TEMPERATURE=0.7
TOP_P=0.95
TOP_K=40
